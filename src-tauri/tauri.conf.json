{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ServerForge",
  "version": "1.13.1",
  "identifier": "com.samue.mc-server-manager",
  "build": {
    "beforeDevCommand": "npm install --no-audit --no-fund && npm run build",
    "beforeBuildCommand": "npm install --no-audit --no-fund && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "ServerForge",
        "width": 1400,
        "height": 860,
        "minWidth": 900,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https://mc-heads.net https://cdn.modrinth.com; style-src 'self' 'unsafe-inline'; font-src 'self'; connect-src 'self' ipc: http://ipc.localhost; object-src 'none'; base-uri 'self'; frame-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
