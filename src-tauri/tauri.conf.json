{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mc-server-manager",
  "version": "0.1.0",
  "identifier": "com.samue.mc-server-manager",
  "build": {
    "beforeDevCommand": "npm install --no-audit --no-fund && npm run build",
    "beforeBuildCommand": "npm install --no-audit --no-fund && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Blockparty — Minecraft Server Manager",
        "width": 1400,
        "height": 860,
        "minWidth": 900,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
